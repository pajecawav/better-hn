{
	"private": true,
	"scripts": {
		"build": "cross-env FORCE_COLOR=1 run-s -l prepare:nitro build:vite build:nitro",
		"build:vite": "vite build",
		"build:nitro": "nitro build",
		"dev": "cross-env FORCE_COLOR=1 npm-run-all -l -s prepare:nitro -p dev:*",
		"dev:vite": "vite --watch build",
		"dev:nitro": "cross-env NODE_OPTIONS=--enable-source-maps nitro dev",
		"preview": "cross-env NODE_OPTIONS=--enable-source-maps node .output/server/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:eslint": "eslint .",
		"lint:tsc": "tsc --noEmit",
		"lint:format": "prettier . --check",
		"format": "prettier . --write",
		"clean": "rimraf dist dist-vite .nitro .output .vercel node_modules/.cache",
		"prepare": "cross-env FORCE_COLOR=1 run-s -l prepare:*",
		"prepare:husky": "husky",
		"prepare:nitro": "nitropack prepare"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@eslint/js": "^10.0.1",
		"@pajecawav/prettier-config": "^1.0.2",
		"@types/js-cookie": "^3.0.6",
		"@vercel/analytics": "^2.0.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.3.0",
		"hono": "^4.12.15",
		"husky": "^9.1.7",
		"js-cookie": "^3.0.5",
		"lint-staged": "^16.4.0",
		"nitropack": "^2.13.4",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"sass": "^1.99.0",
		"tailwind-vars": "^0.1.6",
		"tiny-server-timing": "^0.1.6",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vite-plugin-pwa": "^1.3.0"
	},
	"packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
