{
	"private": true,
	"scripts": {
		"build": "cross-env FORCE_COLOR=1 run-s -l prepare:nitro build:vite build:nitro",
		"build:vite": "vite build",
		"build:nitro": "nitro build",
		"dev": "cross-env FORCE_COLOR=1 npm-run-all -l -s prepare:nitro -p dev:*",
		"dev:vite": "vite --watch build",
		"dev:nitro": "cross-env NODE_OPTIONS=--enable-source-maps nitro dev",
		"preview": "cross-env NODE_OPTIONS=--enable-source-maps node .output/server/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:eslint": "eslint .",
		"lint:tsc": "tsc --noEmit",
		"lint:format": "prettier . --check",
		"format": "prettier . --write",
		"clean": "rimraf dist dist-vite .nitro .output .vercel node_modules/.cache",
		"prepare": "cross-env FORCE_COLOR=1 run-s -l prepare:*",
		"prepare:husky": "husky",
		"prepare:nitro": "nitropack prepare"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@eslint/js": "^10.0.1",
		"@pajecawav/prettier-config": "^1.0.0",
		"@types/js-cookie": "^3.0.6",
		"@vercel/analytics": "^1.6.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.0.0",
		"hono": "^4.11.9",
		"husky": "^9.1.7",
		"js-cookie": "^3.0.5",
		"lint-staged": "^16.2.7",
		"nitropack": "^2.13.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"sass": "^1.97.3",
		"tailwind-vars": "^0.1.6",
		"tiny-server-timing": "^0.1.6",
		"typescript-eslint": "^8.56.0",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.2.0"
	},
	"packageManager": "pnpm@10.30.0+sha512.2b5753de015d480eeb88f5b5b61e0051f05b4301808a82ec8b840c9d2adf7748eb352c83f5c1593ca703ff1017295bc3fdd3119abb9686efc96b9fcb18200937"
