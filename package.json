{
	"private": true,
	"scripts": {
		"build": "cross-env FORCE_COLOR=1 run-s -l prepare:nitro build:vite build:nitro",
		"build:vite": "vite build",
		"build:nitro": "nitro build",
		"dev": "cross-env FORCE_COLOR=1 npm-run-all -l -s prepare:nitro -p dev:*",
		"dev:vite": "vite --watch build",
		"dev:nitro": "cross-env NODE_OPTIONS=--enable-source-maps nitro dev",
		"preview": "cross-env NODE_OPTIONS=--enable-source-maps node .output/server/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:eslint": "eslint .",
		"lint:tsc": "tsc --noEmit",
		"lint:format": "prettier . --check",
		"format": "prettier . --write",
		"clean": "rimraf dist dist-vite .nitro .output .vercel node_modules/.cache",
		"prepare": "cross-env FORCE_COLOR=1 run-s -l prepare:*",
		"prepare:husky": "husky",
		"prepare:nitro": "nitropack prepare"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@pajecawav/prettier-config": "^1.0.0",
		"@types/js-cookie": "^3.0.6",
		"@vercel/analytics": "^2.0.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.1.0",
		"hono": "^4.12.8",
		"husky": "^9.1.7",
		"js-cookie": "^3.0.5",
		"lint-staged": "^16.4.0",
		"nitropack": "^2.13.2",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"sass": "^1.98.0",
		"tailwind-vars": "^0.1.6",
		"tiny-server-timing": "^0.1.6",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.1",
		"vite-plugin-pwa": "^1.2.0"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
