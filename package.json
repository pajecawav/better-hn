{
	"private": true,
	"scripts": {
		"build": "cross-env FORCE_COLOR=1 run-s -l prepare:nitro build:vite build:nitro",
		"build:vite": "vite build",
		"build:nitro": "nitro build",
		"dev": "cross-env FORCE_COLOR=1 npm-run-all -l -s prepare:nitro -p dev:*",
		"dev:vite": "vite --watch build",
		"dev:nitro": "cross-env NODE_OPTIONS=--enable-source-maps nitro dev",
		"preview": "cross-env NODE_OPTIONS=--enable-source-maps node .output/server/index.mjs",
		"lint": "cross-env FORCE_COLOR=1 run-p -l lint:*",
		"lint:eslint": "eslint .",
		"lint:tsc": "tsc --noEmit",
		"lint:format": "prettier . --check",
		"format": "prettier . --write",
		"clean": "rimraf dist dist-vite .nitro .output .vercel node_modules/.cache",
		"prepare": "cross-env FORCE_COLOR=1 run-s -l prepare:*",
		"prepare:husky": "husky",
		"prepare:nitro": "nitropack prepare"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.2",
		"@commitlint/config-conventional": "^20.4.2",
		"@eslint/js": "^10.0.1",
		"@pajecawav/prettier-config": "^1.0.0",
		"@types/js-cookie": "^3.0.6",
		"@vercel/analytics": "^1.6.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.0.2",
		"hono": "^4.11.10",
		"husky": "^9.1.7",
		"js-cookie": "^3.0.5",
		"lint-staged": "^16.2.7",
		"nitropack": "^2.13.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"sass": "^1.97.3",
		"tailwind-vars": "^0.1.6",
		"tiny-server-timing": "^0.1.6",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vite-plugin-pwa": "^1.2.0"
	},
	"packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017"
